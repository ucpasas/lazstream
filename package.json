{
  "name": "lazstream-monorepo",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.1.2",
  "scripts": {
    "dev":   "pnpm --filter @lazstream/viewer dev",
    "build": "pnpm --filter @lazstream/core build && pnpm --filter @lazstream/viewer build",
    "check": "pnpm -r check",
    "preview": "pnpm --filter @lazstream/viewer preview"
  }
}
